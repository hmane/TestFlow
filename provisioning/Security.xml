<pnp:Security xmlns:pnp="http://schemas.dev.office.com/PnP/2022/09/ProvisioningSchema">

  <pnp:SiteGroups>
    <pnp:SiteGroup Title="LW - Admins"
                   Description="System administrators with full access to Legal Workflow"
                   AllowMembersEditMembership="true"
                   AllowRequestToJoinLeave="false"
                   AutoAcceptRequestToJoinLeave="false"
                   OnlyAllowMembersViewMembership="true" />

    <pnp:SiteGroup Title="LW - Submitters"
                   Description="Users who can submit legal review requests"
                   Owner="LW - Admins"
                   AllowMembersEditMembership="false"
                   AllowRequestToJoinLeave="false"
                   AutoAcceptRequestToJoinLeave="false"
                   OnlyAllowMembersViewMembership="true" />

    <pnp:SiteGroup Title="LW - Legal Admins"
                   Description="Legal administrators who can triage and manage all requests"
                   Owner="LW - Admins"
                   AllowMembersEditMembership="false"
                   AllowRequestToJoinLeave="false"
                   AutoAcceptRequestToJoinLeave="false"
                   OnlyAllowMembersViewMembership="true" />

    <pnp:SiteGroup Title="LW - Attorney Assigners"
                   Description="Committee members who can assign attorneys to requests"
                   Owner="LW - Admins"
                   AllowMembersEditMembership="false"
                   AllowRequestToJoinLeave="false"
                   AutoAcceptRequestToJoinLeave="false"
                   OnlyAllowMembersViewMembership="true" />

    <pnp:SiteGroup Title="LW - Attorneys"
                   Description="Attorneys who can review and approve assigned legal requests"
                   Owner="LW - Admins"
                   AllowMembersEditMembership="false"
                   AllowRequestToJoinLeave="false"
                   AutoAcceptRequestToJoinLeave="false"
                   OnlyAllowMembersViewMembership="true" />

    <pnp:SiteGroup Title="LW - Compliance Reviewers"
                   Description="Compliance users who can review compliance aspects of requests"
                   Owner="LW - Admins"
                   AllowMembersEditMembership="false"
                   AllowRequestToJoinLeave="false"
                   AutoAcceptRequestToJoinLeave="false"
                   OnlyAllowMembersViewMembership="true" />
  </pnp:SiteGroups>

  <pnp:Permissions>
    <pnp:RoleAssignments>
      <pnp:RoleAssignment Principal="LW - Admins" RoleDefinition="Full Control" />
      <pnp:RoleAssignment Principal="LW - Submitters" RoleDefinition="Read" />
      <pnp:RoleAssignment Principal="LW - Legal Admins" RoleDefinition="Read" />
      <pnp:RoleAssignment Principal="LW - Attorney Assigners" RoleDefinition="Read" />
      <pnp:RoleAssignment Principal="LW - Attorneys" RoleDefinition="Read" />
      <pnp:RoleAssignment Principal="LW - Compliance Reviewers" RoleDefinition="Read" />
    </pnp:RoleAssignments>
  </pnp:Permissions>



</pnp:Security>
